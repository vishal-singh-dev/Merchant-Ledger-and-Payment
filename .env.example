ENV=dev
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=logs/app.log
LOG_FILE_MAX_BYTES=5242880
LOG_FILE_BACKUP_COUNT=5
DATABASE_URL=postgresql+psycopg://ledger:ledger@localhost:5432/ledger
BROKER_TYPE=kafka

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=merchant-events
KAFKA_DLQ_TOPIC=merchant-events-dlq
KAFKA_GROUP_ID=merchant-processor

AWS_REGION=us-east-1
LOCALSTACK_ENDPOINT_URL=http://localhost:4566
SQS_QUEUE_URL=http://localhost:4566/000000000000/merchant-events.fifo
SQS_DLQ_URL=http://localhost:4566/000000000000/merchant-events-dlq

OUTBOX_POLL_SECONDS=1
OUTBOX_BATCH_SIZE=50
